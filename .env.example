# ── Copy this file to .env and fill in your values ──────────────────────────
# NEVER commit .env to Git

NODE_ENV=production
PORT=5000

# MongoDB — get free cluster at mongodb.com/atlas
MONGODB_URI=mongodb://127.0.0.1:27017/suchitra_financial

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# First admin account (used by: node scripts/seed.js)
ADMIN_EMAIL=admin@suchitrafinancial.com
ADMIN_PASSWORD=ChangeMe@123

# Gmail SMTP — generate App Password at: myaccount.google.com → Security → App passwords
EMAIL_SERVICE=gmail
EMAIL_USER=suchitrafinserv@gmail.com
EMAIL_PASS=YOUR_GMAIL_APP_PASSWORD

# Your frontend domain (for CORS)
FRONTEND_URL=http://localhost:3000

# Link in admin notification emails
ADMIN_URL=https://suchitrafinancial.com
